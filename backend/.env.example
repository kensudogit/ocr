# ════════════════════════════════════════════════════════════════════
# 税理士事務所 OCR システム — 環境設定ファイル
# このファイルを .env にコピーして各値を設定してください
# cp .env.example .env
# ════════════════════════════════════════════════════════════════════

# ── データベース ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://ocr:ocr_pass@localhost:5432/ocr_db

# ── OCR エンジン ──────────────────────────────────────────────────
# "paddle" = ローカルPaddleOCR（デフォルト）
# "auto"   = PaddleOCR → 信頼度低の場合 VLM にフォールバック
OCR_ENGINE=auto

# ════════════════════════════════════════════════════════════════════
# AI デプロイメントモード（セキュリティ・コンプラ要件 最重要）
# ════════════════════════════════════════════════════════════════════
#
# ① cloud   : OpenAI/Gemini を直接利用（ZDR設定付き）
#             - 高精度・低コスト・導入簡単
#             - データは OpenAI/Google のサーバを経由（国外の可能性あり）
#             - ZDR: API 利用時は学習に使用されない（利用規約 Section 3）
#
# ② hybrid  : 機微情報をローカルでマスクしてからクラウド AI へ送信
#             - マイナンバー・口座番号をプレースホルダに置換
#             - AI には匿名化されたテキストのみ送信
#             - セキュリティとコスト精度のバランス（推奨）
#
# ③ bedrock : AWS Bedrock（東京: ap-northeast-1 / 大阪: ap-northeast-3）
#             - データが国内リージョンから外に出ない
#             - 電子帳簿保存法・金融機関向けセキュリティ要件に対応
#             - 要: AWS アカウント + Bedrock モデルアクセス有効化
#
# ④ vertex  : Google Vertex AI（東京: asia-northeast1）
#             - データ常駐ポリシーで国内保管を保証
#             - 要: GCP プロジェクト + Vertex AI API 有効化
#
# ⑤ onprem  : 完全ローカル（PaddleOCR + Ollama）
#             - インターネット不要・完全オフライン動作
#             - 要: Ollama インストール + llama3.2-vision モデル取得
#
AI_DEPLOYMENT_MODE=hybrid

# ── 実務プロファイル（地方中規模税理士事務所向け） ───────────────
# tax_firm: 月500枚+・高セキュリティ・書類種別最適化前処理
PRACTICE_PROFILE=tax_firm
BATCH_MAX_FILES=500
BATCH_CONCURRENCY=3
BATCH_CONCURRENCY_PEAK=5
REQUIRE_REVIEW_HANDWRITTEN=true
REQUIRE_REVIEW_CARD_STATEMENT=true

# ── VLM（Vision Language Model）── ① cloud / ② hybrid モード用 ──
# OpenAI GPT-4o（ZDR: API経由のデータは学習に使用されない）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini  # gpt-4o（高精度）or gpt-4o-mini（高速・低コスト）

# Google Gemini（代替 VLM）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── AWS Bedrock ── ③ bedrock モード用 ───────────────────────────
# 東京リージョン: ap-northeast-1 / 大阪リージョン: ap-northeast-3
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# 対応モデル: anthropic.claude-3-5-sonnet-20241022-v2:0
#             anthropic.claude-3-haiku-20240307-v1:0（低コスト）
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Google Vertex AI ── ④ vertex モード用 ───────────────────────
# 東京: asia-northeast1 / 大阪: asia-northeast2
GCP_PROJECT_ID=
VERTEX_LOCATION=asia-northeast1

# ── Ollama（完全ローカル）── ⑤ onprem モード用 ─────────────────
# セットアップ: ollama pull llama3.2-vision && ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision

# ── Google Cloud Vision API（手書き書類精度向上）──────────────────
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_PROJECT_ID=

# ── 認識率向上 OCR パイプライン（OpenCV + Azure DI + OpenAI）──────
# hybrid       : OpenCV → Azure DI → OpenAI 後処理（推奨）
# azure_openai : Azure DI + OpenAI のみ
# vlm          : 従来の VLM のみ
OCR_PIPELINE_MODE=hybrid
USE_OPENCV_PREPROCESS=true
USE_OPENAI_POSTPROCESS=true

# Azure Document Intelligence（Form Recognizer）
# Azure Portal → Document Intelligence リソース → キーとエンドポイント
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
AZURE_DI_MODEL_DEFAULT=prebuilt-read
AZURE_DI_MODEL_INVOICE=prebuilt-invoice
AZURE_DI_MODEL_RECEIPT=prebuilt-receipt
AZURE_DI_MODEL_CARD=prebuilt-read

# OpenAI 後処理モデル（テキスト補正 — Vision より低コスト）
OPENAI_POSTPROCESS_MODEL=gpt-4o-mini

# ── freee 公式 API 連携 ────────────────────────────────────────────
# freee アプリ登録: https://developer.freee.co.jp/
FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=
FREEE_ACCESS_TOKEN=   # 開発用: 直接アクセストークン入力
FREEE_COMPANY_ID=     # 事業所ID（freee管理画面で確認）

# ════════════════════════════════════════════════════════════════════
# PII マスク設定（② hybrid モード推奨設定）
# ════════════════════════════════════════════════════════════════════
# AI に送信する前に以下の機密情報を自動マスク（プレースホルダに置換）
# hybrid モードでは true 推奨、cloud モードでは任意
PII_MASK_BANK_ACCOUNTS=true   # 銀行口座番号: [BANK_ACCOUNT_0] に置換
PII_MASK_MY_NUMBER=true       # マイナンバー: [MY_NUMBER_0] に置換
PII_MASK_CARD_NUMBERS=true    # クレジットカード番号: [CARD_NUMBER_0] に置換
PII_MASK_PHONE_NUMBERS=false  # 電話番号: OFF（取引先特定に必要なため）

# ════════════════════════════════════════════════════════════════════
# 電子帳簿保存法（スキャナ保存）要件設定
# ════════════════════════════════════════════════════════════════════
# 原本画像の保存先（法定保存期間: 7年 or 10年）
# 変更後のファイルは読み取り専用に設定し改ざん防止
ORIGINALS_DIR=./originals
# スキャン解像度下限（法定: 200dpi 以上）
SCAN_MIN_DPI=200
# タイムスタンプ付与期限（営業日数: 受領後 2 営業日以内）
TIMESTAMP_DEADLINE_DAYS=2

# ── ファイル保存 ──────────────────────────────────────────────────
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=50

# ── 画像前処理 ────────────────────────────────────────────────────
ENHANCE_THERMAL_PAPER=true
AUTO_ROTATE=true
# ノイズ除去レベル: 0=なし, 1=弱, 2=中(推奨), 3=強
DENOISE_LEVEL=2

# ── バックグラウンドタスク ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_ENABLED=false

# ════════════════════════════════════════════════════════════════════
# セキュリティ設定
# ════════════════════════════════════════════════════════════════════
# JWT/セッション署名鍵（本番環境では強力なランダム値に変更必須）
SECRET_KEY=change-me-in-production-use-strong-random-value
# 原本画像の保存時暗号化（AES-256）: 本番では true 推奨
ENCRYPT_STORED_FILES=false

# ── CORS ─────────────────────────────────────────────────────────
# 本番環境では実際のドメインを設定すること
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── アプリ設定 ────────────────────────────────────────────────────
DEBUG=false
