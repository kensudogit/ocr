# Force LF line endings for shell scripts (CRLF breaks bash on Linux)
*.sh text eol=lf

# Force LF for all text files in Docker context
Dockerfile text eol=lf
*.toml text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.bat text eol=crlf
